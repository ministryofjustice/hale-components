{
	"name": "ministryofjustice/hale-components",
	"description": "Functions that are commonly used across the Hale Platform",
	"keywords": [
		"wordpress"
	],
	"type": "wordpress-plugin",
	"require": {
		"composer/installers": "~1.0 || ^2.0"
	},
	"require-dev": {
		"composer/composer": "*"
	},
	"autoload": {
		"psr-4": {
			"MOJComponents\\": "component/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	}
}
